---
// Fixed, pure-CSS cosmic backdrop: tiled star layers + drifting nebula glows.
// Sits behind all content (negative z-index), hidden from assistive tech.
---

<div aria-hidden="true" class="cosmic-bg">
	<div class="cosmic-nebula"></div>
	<div class="stars stars-sm"></div>
	<div class="stars stars-md"></div>
	<div class="stars stars-lg"></div>
</div>
