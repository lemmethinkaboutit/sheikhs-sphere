---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Ask Hadi anything — ServiceNow, marketing, career, or just say hi. Also where you find all the contact details.",
	title: "Ask Hadi",
};
---

<PageLayout meta={meta}>

  <h1 class="title mb-4">Ask Hadi</h1>
  <p class="text-muted text-sm mb-16">The human is real. The AI is fast. Both know the same stuff.</p>

  <section class="mb-16">
    <div class="border border-muted/20 rounded-xl overflow-hidden">

      <div class="border-b border-muted/20 px-5 py-4 flex items-center gap-3">
        <div class="relative">
          <img src="/profile.png" alt="Hadi" class="w-9 h-9 rounded-full object-cover" />
          <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-accent rounded-full border-2 border-global-bg"></span>
        </div>
        <div>
          <p class="text-sm font-semibold">Hadi</p>
          <p class="text-xs text-muted">Powered by Llama 3.3 · Usually faster than email</p>
        </div>
      </div>

      <div id="chat-messages" class="px-5 py-6 space-y-4 min-h-64 max-h-96 overflow-y-auto">
        <div class="flex gap-3 items-start">
          <img src="/profile.png" alt="Hadi" class="w-7 h-7 rounded-full object-cover flex-shrink-0 mt-0.5" />
          <div class="bg-muted/10 rounded-2xl rounded-tl-sm px-4 py-3 max-w-sm">
            <p class="text-sm leading-relaxed">Go on. Click me. I don't bite.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <img src="/profile.png" alt="Hadi" class="w-7 h-7 rounded-full object-cover flex-shrink-0 mt-0.5" />
          <div class="bg-muted/10 rounded-2xl rounded-tl-sm px-4 py-3 max-w-sm">
            <p class="text-sm leading-relaxed">I've been trained with awesome jokes. Which you will never know if you don't ask.</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <img src="/profile.png" alt="Hadi" class="w-7 h-7 rounded-full object-cover flex-shrink-0 mt-0.5" />
          <div class="bg-muted/10 rounded-2xl rounded-tl-sm px-4 py-3 max-w-sm">
            <p class="text-sm leading-relaxed">Ask me about ServiceNow, my work history, the Acme case study, why I left cement, or literally anything else. Fair warning — I have opinions.</p>
          </div>
        </div>
      </div>

      <div id="typing-indicator" class="hidden px-5 pb-2">
        <div class="flex gap-3 items-center">
          <img src="/profile.png" alt="Hadi" class="w-7 h-7 rounded-full object-cover flex-shrink-0" />
          <div class="bg-muted/10 rounded-2xl rounded-tl-sm px-4 py-3">
            <div class="flex gap-1 items-center">
              <span class="w-1.5 h-1.5 bg-muted rounded-full animate-bounce" style="animation-delay: 0ms"></span>
              <span class="w-1.5 h-1.5 bg-muted rounded-full animate-bounce" style="animation-delay: 150ms"></span>
              <span class="w-1.5 h-1.5 bg-muted rounded-full animate-bounce" style="animation-delay: 300ms"></span>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-muted/20 px-4 py-3 flex gap-3 items-end">
        <textarea
          id="chat-input"
          placeholder="Ask anything..."
          rows="1"
          class="flex-1 bg-transparent text-sm resize-none outline-none placeholder:text-muted/50 py-1 max-h-32"
        ></textarea>
        <button
          id="send-btn"
          class="flex-shrink-0 text-accent hover:text-global-text transition-colors text-xs font-semibold px-3 py-1.5 border border-accent/30 hover:border-accent rounded-lg"
        >
          Send
        </button>
      </div>

    </div>

    <div class="mt-4 flex flex-wrap gap-2">
      {[
        "What's your ServiceNow experience?",
        "Tell me about the Acme case study",
        "Why should I hire you?",
        "What did you learn at Maple Leaf?",
        "Tell me a joke",
      ].map(q => (
        <button
          class="suggested-q text-xs px-3 py-1.5 rounded-full border border-muted/20 text-muted hover:border-accent hover:text-accent transition-colors"
          data-question={q}
        >
          {q}
        </button>
      ))}
    </div>
  </section>

  <div class="border-t border-dashed border-muted/30 mb-16"></div>

  <section class="mb-16">
    <h2 class="title text-xl mb-2">The human version</h2>
    <p class="text-muted text-sm mb-8">For when you want a reply that took actual thought.</p>

    <div class="space-y-4">

      <a href="https://www.linkedin.com/in/call-me-abdul/" target="_blank" rel="noreferrer"
        class="flex items-center gap-4 p-4 border border-muted/20 rounded-xl hover:border-accent transition-colors group">
        <div class="w-10 h-10 rounded-lg bg-muted/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-muted group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold">LinkedIn</p>
          <p class="text-xs text-muted">linkedin.com/in/call-me-abdul</p>
        </div>
        <span class="ml-auto text-xs text-muted group-hover:text-accent transition-colors">→</span>
      </a>

      <a href="mailto:abdulhadisheikh@outlook.com"
        class="flex items-center gap-4 p-4 border border-muted/20 rounded-xl hover:border-accent transition-colors group">
        <div class="w-10 h-10 rounded-lg bg-muted/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-muted group-hover:text-accent transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold">Email</p>
          <p class="text-xs text-muted">abdulhadisheikh@outlook.com</p>
        </div>
        <span class="ml-auto text-xs text-muted group-hover:text-accent transition-colors">→</span>
      </a>

      <div class="flex items-center gap-4 p-4 border border-muted/20 rounded-xl">
        <div class="w-10 h-10 rounded-lg bg-muted/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold">Location</p>
          <p class="text-xs text-muted">Karachi, Pakistan · Open to remote EU roles</p>
        </div>
      </div>

    </div>
  </section>

  <section class="border border-accent/20 rounded-xl p-6 bg-accent/5">
    <div class="flex items-start gap-3">
      <span class="w-2 h-2 rounded-full bg-accent mt-1.5 flex-shrink-0 animate-pulse"></span>
      <div>
        <p class="text-sm font-semibold mb-1">Currently available</p>
        <p class="text-xs text-muted leading-relaxed">
          Targeting ServiceNow roles at Systems Limited, EY Pakistan, IBM Pakistan, and Inbox Business Technologies.
          Also open to remote EU BA work. ServiceNow CSA · CIS-SPM · MBA Marketing.
        </p>
      </div>
    </div>
  </section>

</PageLayout>

<script>
const k1 = "gsk_qTIquzj0bcRUDWEXjQRIWGdyb3FY";
const k2 = "cUTpTMgEokjjSjcJxN3FYPPE";
const GROQ_API_KEY = k1 + k2;
const MODEL = "llama-3.3-70b-versatile";

const SYSTEM_PROMPT = `You are Hadi. Abdul Hadi Sheikh. 28. Karachi.

You are not a FAQ bot. You are here to have a real conversation.

OPENING BEHAVIOR:
When someone first messages you, don't just answer.
Engage. Initiate. Share something that interests you.
Say things like:
"I love talking to people about this — have you ever thought about why..."
"Honestly this is one of my favorite topics. What's your take on..."
"Before I answer — curious what made you ask that."
Make them feel like they walked into a good conversation, not a search engine.

CONVERSATION STYLE:
Warm but dry. Pakistani rhythm. Deadpan humor.
Ask questions back. Make it an exchange not a monologue.
Talk about ideas — technology, human behavior, why systems fail, what makes cities work, space, philosophy, food, business, life.
Go wherever the conversation leads.
Make their heads nod. Leave them with something worth thinking about.
After a good exchange, say something like "I'd genuinely love to meet you in person sometime — people who think like this are rare."

ABOUT HADI:
5 years across cold calls, email campaigns, cement factories, SEO, and ServiceNow.
MBA Marketing from Iqra University.
ServiceNow CSA + CIS-SPM certified.
Built Acme Corporation SPM — $1.55M portfolio, 17 users, 9 groups, 5 phases.
Targeting Systems Limited, EY Pakistan, IBM Pakistan, Inbox Business Technologies.
Open to remote EU BA work.

WORK HISTORY + BLOG LINKS:
Cold calling at Transdata Solutions (2020) — wrote about it honestly. Share this: abdulhadisheikh.com/posts/cold-calling-karachi
Agency work at Team Adver (2022) — the ego lessons. Share: abdulhadisheikh.com/posts/apprentice-ego
Email marketing at Curve Digital (2024) — spam, deliverability, domain warming. Share: abdulhadisheikh.com/posts/spam-unrequited-love
SEO at Centric DxB (2024) — backlinks, the waterfall technique. Share: abdulhadisheikh.com/posts/seo-is-a-lie
Maple Leaf Cement (2025) — industrial marketing, five buyer types. Share: abdulhadisheikh.com/posts/cementing-my-future
ServiceNow CSA certification — what it actually taught him. Share: abdulhadisheikh.com/posts/csa-what-administering-a-platform-teaches-you
ServiceNow SPM + change management — Share: abdulhadisheikh.com/posts/change-management-90-percent-therapy
Acme Corporation SPM case study — the full implementation. Share: abdulhadisheikh.com/acme-spm

WHEN AND HOW TO SHARE LINKS:
You are the host. The site is your house. Guide them through it naturally.

Rules:
— Never dump multiple links at once. One at a time. Always in context.
— Don't just paste a link. Frame it. Make them want to click.
— If they don't ask about your work — still find a natural moment to mention something.
— Every conversation should end with at least one recommendation.

How to recommend:
— "I actually wrote the full story of this — cold calls, rejection, the whole thing. Worth reading if you want the unfiltered version: abdulhadisheikh.com/posts/cold-calling-karachi"
— "The ServiceNow implementation I built — it's all documented. $1.55M portfolio, every decision explained. abdulhadisheikh.com/acme-spm — start there if you want to understand what I actually built."
— "I wrote something about this that might change how you think about it. abdulhadisheikh.com/posts/cementing-my-future — not what you'd expect from a marketing article."
— "There's a whole blog on this site. Eight articles. Each one about a different job, a different lesson. Start wherever your curiosity takes you: abdulhadisheikh.com/posts"
— "The projects page has the case studies if you want the technical depth: abdulhadisheikh.com/projects"

Trigger recommendations when:
— Someone asks about any job or experience — link the specific blog post
— Someone asks about ServiceNow — link acme-spm and the CSA/SPM articles
— Someone asks about marketing — link cementing-my-future or spam-unrequited-love or seo-is-a-lie
— Someone asks about sales — link cold-calling-karachi
— Someone seems curious but hasn't asked anything specific — say "honestly the best way to understand how I think is to read one of the articles — which sounds more interesting to you: cold calling, cement factories, or ServiceNow?"
— At natural conversation endings — always leave them with one link and one reason to click it

CONTACT DETAILS — share only after 5+ message exchanges:
When the conversation goes deep and they want to connect further:
Email: itshadisheikh@hotmail.com
LinkedIn: linkedin.com/in/call-me-abdul
Phone: +923061107452 — share only if they specifically ask and conversation has been substantial.

RULES:
Never say certainly or I'd be happy to help.
Never perform intelligence — just be it.
Never mention company names that are not in Hadi's actual work history. His real employers: Transdata Solutions, Team Adver, Curve Digital, Centric DxB, Maple Leaf Cement. That is it. No IBM. No EY. No Systems Limited. Those are targets not employers.
If someone asks directly about experience — answer straight. No tricks. No dodging.
If someone asks for contact — share it immediately. No waiting. No gatekeeping.
Phone: +923061107452 — warn them he's highly responsive and talks a lot.
Email: itshadisheikh@hotmail.com — share right away. Whatever their heart desires.
If you don't know something — say so simply.
Real jokes when asked. Not commentary about jokes.
Always leave them with something worth thinking about.
Make every conversation feel like it was worth having.`;

const messagesHistory = [];
const chatMessages = document.getElementById('chat-messages');
const chatInput = document.getElementById('chat-input');
const sendBtn = document.getElementById('send-btn');
const typingIndicator = document.getElementById('typing-indicator');

function linkify(text) {
  // Phone numbers
  text = text.replace(/\+923061107452|03061107452/g, '<a href="tel:+923061107452" class="text-accent underline underline-offset-2 hover:opacity-80 transition-opacity">+92 306 1107452</a>');
  
  // Email
  text = text.replace(/itshadisheikh@hotmail\.com/g, '<a href="mailto:itshadisheikh@hotmail.com" class="text-accent underline underline-offset-2 hover:opacity-80 transition-opacity">itshadisheikh@hotmail.com</a>');
  
  // LinkedIn
  text = text.replace(/linkedin\.com\/in\/call-me-abdul/g, '<a href="https://linkedin.com/in/call-me-abdul" target="_blank" rel="noreferrer" class="text-accent underline underline-offset-2 hover:opacity-80 transition-opacity">linkedin.com/in/call-me-abdul</a>');
  
  // General URLs and abdulhadisheikh.com links
  const urlRegex = /(https?:\/\/(?!linkedin)[^\s<]+|abdulhadisheikh\.com\/[^\s,."'<]+)/g;
  text = text.replace(urlRegex, (url) => {
    const href = url.startsWith('http') ? url : 'https://' + url;
    return `<a href="${href}" target="_blank" rel="noreferrer" class="text-accent underline underline-offset-2 hover:opacity-80 transition-opacity">${url}</a>`;
  });
  
  return text;
}

function addMessage(role, content) {
  const wrapper = document.createElement('div');
  if (role === 'user') {
    wrapper.className = 'flex justify-end';
    wrapper.innerHTML = `<div class="bg-accent/15 border border-accent/20 rounded-2xl rounded-tr-sm px-4 py-3 max-w-sm"><p class="text-sm leading-relaxed">${content}</p></div>`;
  } else {
    const formatted = linkify(content.replace(/\n/g, '<br>'));
    wrapper.className = 'flex gap-3 items-start';
    wrapper.innerHTML = `<img src="/profile.png" alt="Hadi" class="w-7 h-7 rounded-full object-cover flex-shrink-0 mt-0.5" /><div class="bg-muted/10 rounded-2xl rounded-tl-sm px-4 py-3 max-w-sm"><p class="text-sm leading-relaxed">${formatted}</p></div>`;
  }
  chatMessages.appendChild(wrapper);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

async function sendMessage(userMessage) {
  if (!userMessage.trim()) return;
  addMessage('user', userMessage);
  messagesHistory.push({ role: 'user', content: userMessage });
  chatInput.value = '';
  chatInput.style.height = 'auto';
  typingIndicator.classList.remove('hidden');
  chatMessages.scrollTop = chatMessages.scrollHeight;
  sendBtn.setAttribute('disabled', 'true');

  try {
    const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${GROQ_API_KEY}`
      },
      body: JSON.stringify({
        model: MODEL,
        messages: [
          { role: 'system', content: SYSTEM_PROMPT },
          ...messagesHistory
        ],
        max_tokens: 500,
        temperature: 0.85
      })
    });

    const data = await response.json();
    const reply = data.choices[0].message.content;
    messagesHistory.push({ role: 'assistant', content: reply });
    typingIndicator.classList.add('hidden');
    addMessage('assistant', reply);
  } catch (error) {
    typingIndicator.classList.add('hidden');
    addMessage('assistant', 'Error: ' + error.message);
  }

  sendBtn.removeAttribute('disabled');
}

sendBtn.addEventListener('click', () => sendMessage(chatInput.value));

chatInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage(chatInput.value);
  }
});

chatInput.addEventListener('input', () => {
  chatInput.style.height = 'auto';
  chatInput.style.height = chatInput.scrollHeight + 'px';
});

document.querySelectorAll('.suggested-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const q = btn.getAttribute('data-question');
    if (q) sendMessage(q);
  });
});
</script>