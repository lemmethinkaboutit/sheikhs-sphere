---
import PageLayout from "@/layouts/Base.astro";

export const prerender = true;

const meta = {
	description:
		"Business process automation, change & project management, and marketing & sales process consulting. Scoped engagements, clear deliverables, honest advice — wherever you are in the world.",
	title: "Services — Business Process Automation, Change Management, Marketing & Sales",
};

const CONTACT_EMAIL = "magic.alive11@gmail.com";

const services = [
	{
		title: "Business Process Automation",
		category: "Workflows · Intake · Dashboards",
		description:
			"I take the work your team does by hand — intake queues, approvals, status chasing, reporting — and turn it into workflows that route, score, and track themselves. Demand intake with scoring, role-based access, financial tracking, and the executive dashboard that answers \"are we on track?\" without anyone compiling a deck. Process first, configuration second.",
		goodFit:
			"Work arrives from every direction, lives in spreadsheets and inboxes, and leadership keeps asking for visibility nobody can produce.",
		proof: { label: "Read the Acme implementation case study →", href: "/acme-spm" },
		tags: ["Workflow Automation", "Demand Intake", "Approvals", "Executive Dashboards"],
		credential: "Certified Implementation Specialist",
	},
	{
		title: "Change & Project Management",
		category: "Governance · Portfolios · Adoption",
		description:
			"Change management is 90% therapy and 10% technology. I run projects with clear governance and visible portfolios — and I treat adoption as a deliverable, not a hope. Stakeholder alignment, risk and compliance visibility, and the honest conversations that stop a rollout from becoming shelfware.",
		goodFit:
			"Projects launch but don't land: the tool is live, the old spreadsheet is still the real system, and nobody can say which initiatives are on track.",
		proof: { label: "Read: change management is 90% therapy →", href: "/posts/change-management-90-percent-therapy/" },
		tags: ["Change Management", "Project Governance", "Portfolio Visibility", "Risk & Compliance"],
		credential: "CSA · CIS-SPM certified",
	},
	{
		title: "Marketing & Sales Process",
		category: "Positioning · Email · SEO · Pipeline",
		description:
			"Strategy grounded in five years of doing the work — not just planning it. Brand positioning, email campaigns that get opened, SEO that targets what buyers actually search, plus outreach scripts, qualification frameworks, and pipeline process built by someone who has personally made the cold calls and heard every objection.",
		goodFit:
			"You're spending on marketing but can't trace it to revenue, or your team is making calls and sending emails and conversations still aren't converting.",
		proof: { label: "Read my PhD in rejection →", href: "/posts/cold-calling-karachi/" },
		tags: ["Positioning", "Email Marketing", "SEO", "Sales Pipeline"],
		credential: "MBA Marketing · Google certified",
	},
];
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">Services</h1>
	<p class="text-muted mb-4 text-sm">
		Three domains, one operator. Fully remote, everyone welcome — scoped engagements, clear deliverables.
	</p>
	<p class="mb-16 text-sm">
		Not sure which fits? <a href={`mailto:${CONTACT_EMAIL}`} class="text-accent hover:underline">Email me</a> with the problem — I'll tell you honestly if I'm the right person for it.
	</p>

	<div class="space-y-6">
		{services.map((service) => (
			<div class="rounded-xl border border-muted/20 p-6 transition-all duration-200 hover:border-accent">
				<div class="flex items-start justify-between gap-4 mb-3">
					<div>
						<span class="text-xs text-muted uppercase tracking-widest">{service.category}</span>
						<h2 class="text-base font-bold mt-1">{service.title}</h2>
					</div>
					<span class="text-xs px-2 py-1 rounded-full bg-accent/15 text-accent border border-accent/20 flex-shrink-0">{service.credential}</span>
				</div>
				<p class="text-sm text-muted leading-relaxed mb-4">{service.description}</p>
				<p class="text-sm leading-relaxed mb-4">
					<span class="font-semibold text-accent">Good fit if:</span>
					<span class="text-muted"> {service.goodFit}</span>
				</p>
				<div class="flex flex-wrap gap-2 mb-4">
					{service.tags.map((tag) => (
						<span class="text-xs px-2 py-0.5 rounded border border-muted/20 text-muted">{tag}</span>
					))}
				</div>
				<div class="flex flex-wrap items-center gap-4">
					<a
						href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(service.title)}`}
						class="text-xs px-3 py-1.5 rounded-lg bg-accent/15 text-accent border border-accent/30 hover:bg-accent/25 transition-colors font-semibold"
					>
						Start a conversation →
					</a>
					{service.proof && (
						<a href={service.proof.href} class="text-xs text-accent hover:underline">{service.proof.label}</a>
					)}
				</div>
			</div>
		))}
	</div>

	<div class="mt-16 pt-8 border-t border-dashed border-muted/30">
		<h2 class="title text-lg text-accent mb-4">How an engagement starts</h2>
		<ol class="space-y-3 text-sm">
			<li class="flex gap-4">
				<span class="flex-shrink-0 w-6 h-6 rounded-full border border-accent/30 flex items-center justify-center text-accent text-xs">1</span>
				<span class="text-muted">You email me the problem — a few honest sentences, no brief required.</span>
			</li>
			<li class="flex gap-4">
				<span class="flex-shrink-0 w-6 h-6 rounded-full border border-accent/30 flex items-center justify-center text-accent text-xs">2</span>
				<span class="text-muted">We get on a call. I ask questions, you decide if I understand your situation.</span>
			</li>
			<li class="flex gap-4">
				<span class="flex-shrink-0 w-6 h-6 rounded-full border border-accent/30 flex items-center justify-center text-accent text-xs">3</span>
				<span class="text-muted">You get a written scope with deliverables and a price. No surprises after that.</span>
			</li>
		</ol>
		<a
			href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent("Project inquiry")}`}
			class="btn-glow inline-block mt-8 text-sm px-5 py-2.5 rounded-lg bg-accent/15 text-accent border border-accent/30 hover:bg-accent/25 transition-colors font-semibold"
		>
			Email me about a project →
		</a>
	</div>
</PageLayout>
