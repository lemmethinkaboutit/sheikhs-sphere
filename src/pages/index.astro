---
import { type CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const prerender = true;

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

// Pinned Posts, set to a max of 3
const MAX_PINNED_POSTS = 3;
const pinnedPosts = allPostsByDate
	.values()
	.filter((p) => p.data.pinned)
	.take(MAX_PINNED_POSTS)
	.toArray();
---

<PageLayout
	meta={{
		title: "Business Process Automation, Change Management & Marketing Consultant",
		description:
			"I automate business processes, manage change and projects people actually adopt, and build marketing and sales processes that convert. Warm, honest consulting — wherever you are.",
	}}
>
	<section>
	<h1 class="title title-gradient mb-3 text-3xl sm:text-4xl">Sheikh's Sphere</h1>
	<p class="text-muted text-xs mb-10 tracking-widest uppercase">Business Process Automation · Change &amp; Project Management · Marketing &amp; Sales Process</p>
	<div class="flex flex-col sm:flex-row items-start gap-8 mb-8">
		<div class="flex-1">
			<p class="mb-4">
				I do three things, and I do them like someone who has actually lived them: I <strong>automate business processes</strong> that drown teams in manual work, I <strong>manage change and projects</strong> so the new way actually sticks, and I <strong>fix marketing and sales processes</strong> so pipelines convert instead of leak.
			</p>
			<p class="mb-4">
				Five years across sales floors, cement factories, and enterprise platforms taught me how businesses actually work — not the MBA version, the real one.
			</p>
			<p class="mb-6">
				Wherever you are in the world, if your processes live in spreadsheets, your projects stall at adoption, or your pipeline leaks — we should talk. This is also where I write honestly about the journey.
			</p>
			<div class="mb-8 flex flex-wrap gap-3">
				<a href="/services/" class="btn-glow text-xs px-4 py-2 rounded-lg bg-accent/15 text-accent border border-accent/30 hover:bg-accent/25 transition-colors font-semibold">See what I do →</a>
				<a href="mailto:magic.alive11@gmail.com" class="text-xs px-4 py-2 rounded-lg border border-muted/30 hover:border-accent hover:text-accent transition-colors font-semibold">Email me</a>
			</div>
			<SocialList />
		</div>
		<div class="flex-shrink-0">
			<img
				src="/profile.webp"
				alt="Abdul Hadi Sheikh"
				width="320"
				height="320"
				fetchpriority="high"
				class="w-40 h-40 rounded-2xl object-cover border-2 border-accent profile-img"
			/>
		</div>
	</div>
	<div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-muted border-t border-dashed border-muted/30 pt-4">
		<span class="uppercase tracking-widest">Credentials</span>
		<span>MBA Marketing</span>
		<span aria-hidden="true">·</span>
		<span>CSA Certified</span>
		<span aria-hidden="true">·</span>
		<span>CIS-SPM Certified</span>
		<span aria-hidden="true">·</span>
		<span>Google Digital Marketing</span>
	</div>
</section>

	{
		pinnedPosts.length > 0 && (
			<section class="mt-16">
				<h2 class="title mb-6 text-xl">Pinned Posts</h2>
				<ul class="space-y-4" role="list">
					{pinnedPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}

	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/posts/">Blog</a>
		</h2>
		<ul class="space-y-4" role="list">
			{
				latestPosts.map((p) => (
					<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>

	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href="/projects/">Projects</a>
		</h2>
		<p class="text-sm">
			Case studies from real work — marketing strategy, brand projects, and platform builds.
			<a href="/projects/" class="text-accent hover:underline">View all projects →</a>
		</p>
	</section>
</PageLayout>